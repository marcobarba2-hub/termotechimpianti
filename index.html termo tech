<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="data:image/png;base64,">
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Termo Tech Impianti | Termoidraulica · Liguria</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --ink: #0e1a2b;
      --paper: #ffffff;
      --steel: #1a3a6b;
      --rust: #e05c00;
      --sea: #2a7d2e;
      --gold: #f47920;
      --mist: #7a9cc0;
      --light-steel: #dde8f5;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--paper);
      color: var(--ink);
      font-family: 'Crimson Pro', Georgia, serif;
      font-weight: 300;
      font-size: 18px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ─── NOISE TEXTURE OVERLAY ─── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.5;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.2rem 3rem;
      background: rgba(244,240,232,0.88);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(44,62,80,0.15);
    }

    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.1em;
      color: var(--steel);
    }
    .nav-logo span { color: var(--sea); }

    .nav-links {
      display: flex; gap: 2.5rem; list-style: none;
    }
    .nav-links a {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--steel);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--sea); }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding-top: 80px;
      position: relative;
      overflow: hidden;
    }

    .hero-left {
      display: flex; flex-direction: column; justify-content: center;
      padding: 6rem 4rem 6rem 6rem;
      position: relative; z-index: 2;
    }

    .hero-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sea);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeUp 0.8s 0.2s forwards;
    }

    .hero-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.5rem, 7vw, 7rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
      color: var(--steel);
      margin-bottom: 2rem;
      opacity: 0;
      animation: fadeUp 0.8s 0.4s forwards;
    }
    .hero-title em {
      color: var(--sea);
      font-style: normal;
    }

    .hero-subtitle {
      font-size: 1.1rem;
      line-height: 1.7;
      color: #4a5568;
      max-width: 440px;
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeUp 0.8s 0.6s forwards;
    }

    .hero-cta {
      display: flex; gap: 1.2rem; flex-wrap: wrap;
      opacity: 0;
      animation: fadeUp 0.8s 0.8s forwards;
    }

    .btn-primary {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 2.2rem;
      background: var(--steel);
      color: var(--paper);
      text-decoration: none;
      border: none; cursor: pointer;
      transition: background 0.25s, transform 0.15s;
      display: inline-block;
    }
    .btn-primary:hover { background: var(--sea); transform: translateY(-2px); }

    .btn-outline {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 2.2rem;
      background: transparent;
      color: var(--steel);
      text-decoration: none;
      border: 1.5px solid var(--steel);
      cursor: pointer;
      transition: all 0.25s;
      display: inline-block;
    }
    .btn-outline:hover { border-color: var(--sea); color: var(--sea); transform: translateY(-2px); }

    .hero-right {
      position: relative; overflow: hidden;
      background: var(--steel);
    }

    .hero-right::before {
      content: '';
      position: absolute; inset: 0;
      background:
        linear-gradient(135deg, var(--sea) 0%, transparent 50%),
        linear-gradient(315deg, #0e3040 0%, transparent 60%);
      opacity: 0.7;
    }

    .hero-grid-pattern {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(201,168,76,0.12) 1px, transparent 1px),
        linear-gradient(90deg, rgba(201,168,76,0.12) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    .hero-schematic {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      opacity: 0;
      animation: fadeIn 1.2s 1s forwards;
    }

    .schematic-svg {
      width: 70%; height: 70%;
      opacity: 0.35;
    }

    .hero-badge {
      position: absolute;
      bottom: 3rem; left: 3rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid var(--gold);
      padding: 0.6rem 1rem;
      opacity: 0;
      animation: fadeIn 1s 1.4s forwards;
    }

    /* ─── DIVIDER LINE ─── */
    .section-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--mist), transparent);
      margin: 0 6rem;
    }

    /* ─── SERVICES ─── */
    .services {
      padding: 8rem 6rem;
      position: relative;
    }

    .section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--sea);
      margin-bottom: 0.8rem;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 4vw, 4.5rem);
      color: var(--steel);
      line-height: 1;
      margin-bottom: 4rem;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border-top: 1px solid var(--light-steel);
      border-left: 1px solid var(--light-steel);
    }

    .service-card {
      padding: 2.5rem 2rem;
      border-right: 1px solid var(--light-steel);
      border-bottom: 1px solid var(--light-steel);
      transition: background 0.3s;
      position: relative;
      overflow: hidden;
    }

    .service-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      height: 3px; width: 0;
      background: var(--sea);
      transition: width 0.4s ease;
    }
    .service-card:hover::after { width: 100%; }
    .service-card:hover { background: rgba(26,110,114,0.04); }

    .service-number {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      color: var(--mist);
      letter-spacing: 0.1em;
      margin-bottom: 1rem;
    }

    .service-icon {
      font-size: 2rem;
      margin-bottom: 1rem;
      display: block;
    }

    .service-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.05em;
      color: var(--steel);
      margin-bottom: 0.8rem;
    }

    .service-desc {
      font-size: 0.95rem;
      color: #5a6a75;
      line-height: 1.6;
    }

    /* ─── ABOUT ─── */
    .about {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 0;
      background: var(--steel);
      color: var(--paper);
    }

    .about-left {
      padding: 7rem 5rem 7rem 6rem;
      display: flex; flex-direction: column; justify-content: center;
    }

    .about-left .section-label { color: var(--gold); }
    .about-left .section-title { color: var(--paper); }

    .about-text {
      font-size: 1.05rem;
      line-height: 1.8;
      color: rgba(244,240,232,0.8);
      margin-bottom: 2rem;
    }

    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(244,240,232,0.15);
    }

    .stat-item {}
    .stat-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      color: var(--gold);
      line-height: 1;
    }
    .stat-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--mist);
      margin-top: 0.3rem;
    }

    .about-right {
      position: relative;
      background: var(--sea);
      overflow: hidden;
      min-height: 500px;
    }

    .about-right::before {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(circle at 70% 30%, rgba(201,168,76,0.2) 0%, transparent 60%),
        linear-gradient(180deg, var(--steel) 0%, transparent 30%);
    }

    .about-right-content {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      justify-content: flex-end;
      padding: 4rem;
    }

    .liguria-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 6rem;
      line-height: 0.9;
      opacity: 0.08;
      color: white;
      letter-spacing: 0.05em;
      pointer-events: none;
    }

    .location-badge {
      display: inline-flex; align-items: center; gap: 0.6rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(201,168,76,0.5);
      padding: 0.6rem 1.2rem;
      width: fit-content;
    }

    /* ─── PROJECTS ─── */
    .projects {
      padding: 8rem 6rem;
      background: var(--paper);
    }

    .projects-header {
      display: flex; justify-content: space-between; align-items: flex-end;
      margin-bottom: 4rem;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      grid-template-rows: auto auto;
      gap: 1.5px;
      background: var(--light-steel);
    }

    .project-card {
      background: var(--paper);
      padding: 3rem;
      position: relative;
      overflow: hidden;
      transition: background 0.3s;
      cursor: default;
    }
    .project-card:hover { background: #eee8d8; }

    .project-card.featured {
      grid-row: span 2;
    }

    .project-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sea);
      background: rgba(26,110,114,0.1);
      padding: 0.3rem 0.7rem;
      display: inline-block;
      margin-bottom: 1.5rem;
    }

    .project-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 0.03em;
      color: var(--steel);
      margin-bottom: 1rem;
    }
    .project-card.featured .project-title {
      font-size: 2.5rem;
    }

    .project-desc {
      font-size: 0.95rem;
      color: #5a6a75;
      line-height: 1.6;
    }

    .project-meta {
      margin-top: 2rem;
      display: flex; gap: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--light-steel);
    }

    .meta-item {}
    .meta-key {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--mist);
    }
    .meta-val {
      font-size: 0.95rem;
      color: var(--steel);
      font-weight: 600;
    }

    /* ─── CONTACT ─── */
    .contact {
      background: var(--ink);
      color: var(--paper);
      padding: 8rem 6rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: start;
    }

    .contact-left .section-label { color: var(--gold); }
    .contact-left .section-title { color: var(--paper); margin-bottom: 1.5rem; }
    .contact-left .about-text { color: rgba(244,240,232,0.7); }

    .contact-info {
      margin-top: 3rem;
      display: flex; flex-direction: column; gap: 1.5rem;
    }

    .contact-item {
      display: flex; align-items: flex-start; gap: 1rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgba(244,240,232,0.1);
    }

    .contact-item-icon {
      font-size: 1.2rem;
      margin-top: 0.1rem;
      flex-shrink: 0;
    }

    .contact-item-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--mist);
      margin-bottom: 0.3rem;
    }

    .contact-item-value {
      color: var(--paper);
      font-size: 1rem;
    }

    .contact-right {}

    .contact-form {
      display: flex; flex-direction: column; gap: 1.2rem;
    }

    .form-group {
      display: flex; flex-direction: column; gap: 0.4rem;
    }

    .form-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--mist);
    }

    .form-input, .form-textarea {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(244,240,232,0.15);
      color: var(--paper);
      padding: 0.9rem 1.1rem;
      font-family: 'Crimson Pro', serif;
      font-size: 1rem;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }
    .form-input:focus, .form-textarea:focus {
      border-color: var(--sea);
    }
    .form-textarea { resize: vertical; min-height: 130px; }

    .form-input::placeholder, .form-textarea::placeholder {
      color: rgba(244,240,232,0.3);
    }

    .btn-send {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 2.2rem;
      background: var(--sea);
      color: var(--paper);
      border: none; cursor: pointer;
      transition: background 0.25s, transform 0.15s;
      align-self: flex-start;
      margin-top: 0.5rem;
    }
    .btn-send:hover { background: #0e4e52; transform: translateY(-2px); }

    /* ─── FOOTER ─── */
    footer {
      background: #070707;
      color: rgba(244,240,232,0.35);
      padding: 2rem 6rem;
      display: flex; justify-content: space-between; align-items: center;
    }

    footer .nav-logo { font-size: 1.1rem; }
    footer .nav-logo span { color: var(--sea); }

    .footer-note {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
    }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      .hero { grid-template-columns: 1fr; }
      .hero-right { display: none; }
      .hero-left { padding: 4rem 2rem 4rem 2rem; }
      .services { padding: 5rem 2rem; }
      .services-grid { grid-template-columns: 1fr; }
      .about { grid-template-columns: 1fr; }
      .about-left { padding: 4rem 2rem; }
      .about-right { min-height: 250px; }
      .projects { padding: 5rem 2rem; }
      .projects-grid { grid-template-columns: 1fr; }
      .project-card.featured { grid-row: span 1; }
      .projects-header { flex-direction: column; gap: 1rem; align-items: flex-start; }
      .contact { grid-template-columns: 1fr; padding: 5rem 2rem; gap: 3rem; }
      footer { padding: 2rem; flex-direction: column; gap: 0.5rem; text-align: center; }
      .section-divider { margin: 0 2rem; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-logo"><img src="data:image/png;base64," alt="Termo Tech Impianti" style="height:120px; width:auto; display:block;"></div>
    <ul class="nav-links">
      <li><a href="#servizi">Servizi</a></li>
      <li><a href="#profilo">Profilo</a></li>
      <li><a href="#progetti">Progetti</a></li>
      <li><a href="#contatti">Contatti</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero" id="home">
    <div class="hero-left">
      <p class="hero-eyebrow">Impiantista Termoidraulico Installatore · Liguria</p>
      <h1 class="hero-title">
        Dall'idraulica<br/>
        al clima:<br/>
        <em>un solo<br/>interlocutore.</em>
      </h1>
      <p class="hero-subtitle">
        Installazione e manutenzione di impianti termoidraulici, sanitari, di riscaldamento e climatizzazione. Lavoro diretto, preciso e affidabile — sulla costa ligure e dintorni.
      </p>
      <div class="hero-cta">
        <a href="#servizi" class="btn-primary">Scopri i servizi</a>
        <a href="#contatti" class="btn-outline">Contattami</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-grid-pattern"></div>
      <div class="hero-schematic">
        <!-- Schematic SVG decorativo -->
        <svg class="schematic-svg" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Pipes horizontal -->
          <line x1="50" y1="120" x2="350" y2="120" stroke="#c9a84c" stroke-width="2"/>
          <line x1="50" y1="200" x2="350" y2="200" stroke="#4a9fa5" stroke-width="2"/>
          <line x1="50" y1="280" x2="350" y2="280" stroke="#c9a84c" stroke-width="2"/>
          <!-- Pipes vertical -->
          <line x1="100" y1="80" x2="100" y2="320" stroke="white" stroke-width="1.5"/>
          <line x1="200" y1="80" x2="200" y2="320" stroke="white" stroke-width="1.5"/>
          <line x1="300" y1="80" x2="300" y2="320" stroke="white" stroke-width="1.5"/>
          <!-- Valves / components -->
          <circle cx="100" cy="120" r="10" stroke="#c9a84c" stroke-width="2" fill="none"/>
          <circle cx="200" cy="200" r="14" stroke="#4a9fa5" stroke-width="2.5" fill="rgba(74,159,165,0.15)"/>
          <circle cx="300" cy="280" r="10" stroke="#c9a84c" stroke-width="2" fill="none"/>
          <rect x="88" y="188" width="24" height="24" stroke="white" stroke-width="1.5" fill="none"/>
          <rect x="188" y="108" width="24" height="24" stroke="white" stroke-width="1.5" fill="none"/>
          <rect x="288" y="268" width="24" height="24" stroke="#4a9fa5" stroke-width="1.5" fill="none"/>
          <!-- Flow arrows -->
          <polyline points="155,118 165,120 155,122" stroke="#c9a84c" stroke-width="1.5" fill="none"/>
          <polyline points="155,198 165,200 155,202" stroke="#4a9fa5" stroke-width="1.5" fill="none"/>
          <polyline points="155,278 165,280 155,282" stroke="#c9a84c" stroke-width="1.5" fill="none"/>
          <!-- Pump symbol -->
          <circle cx="200" cy="200" r="22" stroke="#4a9fa5" stroke-width="1" fill="none" stroke-dasharray="4 3"/>
          <!-- Labels -->
          <text x="60" y="108" fill="#c9a84c" font-size="9" font-family="monospace">P1</text>
          <text x="205" y="178" fill="#4a9fa5" font-size="9" font-family="monospace">PUMP</text>
          <text x="305" y="268" fill="white" font-size="9" font-family="monospace">VLV</text>
          <!-- Dimension lines -->
          <line x1="50" y1="340" x2="350" y2="340" stroke="white" stroke-width="0.5" stroke-dasharray="3 4"/>
          <line x1="50" y1="336" x2="50" y2="344" stroke="white" stroke-width="0.5"/>
          <line x1="350" y1="336" x2="350" y2="344" stroke="white" stroke-width="0.5"/>
          <text x="190" y="355" fill="white" font-size="8" font-family="monospace" opacity="0.6">SCHEMA IMPIANTO</text>
        </svg>
      </div>
      <div class="hero-badge">▸ Installatore Termoidraulico</div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- SERVICES -->
  <section class="services" id="servizi">
    <p class="section-label">// 01 — Cosa faccio</p>
    <h2 class="section-title">Servizi Offerti</h2>
    <div class="services-grid">

      <div class="service-card">
        <div class="service-number">001</div>
        <span class="service-icon">🔥</span>
        <div class="service-title">Impianti Termoidraulici</div>
        <p class="service-desc">Installazione di caldaie a condensazione, pompe di calore, gruppi termici e reti di distribuzione acqua calda. Messa in funzione, collaudo e manutenzione ordinaria e straordinaria.</p>
      </div>

      <div class="service-card">
        <div class="service-number">002</div>
